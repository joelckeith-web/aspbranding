# ═══════════════════════════════════════════════════════════
#  ASP Blog System — Environment Variables
# ═══════════════════════════════════════════════════════════

# ── Anthropic (Claude API for content generation) ──
# Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub (push blog posts to the asp-nextjs repo) ──
# Create a fine-grained personal access token with Contents read/write
# https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-github-username
GITHUB_REPO=asp-nextjs
GITHUB_BRANCH=main

# ── Vercel Cron (authorization for the /api/cron/generate-blog endpoint) ──
# Generate a random secret: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ── Site URL (used for Google Indexing API pings) ──
NEXT_PUBLIC_SITE_URL=https://aspbranding.com

# ── Google Indexing API (optional — for instant index pings) ──
# Requires a Google Cloud service account with the Indexing API enabled.
# The service account email must be added as an owner in Google Search Console.
# Docs: https://developers.google.com/search/apis/indexing-api/v3/quickstart
GOOGLE_INDEXING_CLIENT_EMAIL=blog-indexer@your-project.iam.gserviceaccount.com
GOOGLE_INDEXING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
